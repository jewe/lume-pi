# Lume Wi-Fi Access Point settings (sample)
#
# Copy this file to the Pi and install it as a root-readable env file, e.g.:
#   sudo install -m 600 -o root -g root ./wifi-ap.env.sample /etc/lume-wifi-ap.env
#
# NOTE:
# - Keep this file out of git (store the real one in /etc/).
# - `LUME_WIFI_AP_PSK` must be 8..63 characters.

# The Wi-Fi name shown on your phone.
LUME_WIFI_AP_SSID="Lume-Setup"

# WPA2 password. Change this.
LUME_WIFI_AP_PSK="change-me-please"

# Optional but recommended. Used by hostapd (choose your country code).
LUME_WIFI_AP_COUNTRY="DE"
