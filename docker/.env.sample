# Runtime environment for the Lume Docker Compose stack on Raspberry Pi.
#
# Copy to `lume-pi/docker/.env` and edit values.
#
# Assumption: your Pi is reachable on the LAN via mDNS as:
#   <hostname>.local
#
# IMPORTANT: This file contains secrets.

# --- Core / Rails (required) ---
RAILS_MASTER_KEY=
SECRET_KEY_BASE=

# --- Postgres (required) ---
POSTGRES_DB=energypi
POSTGRES_USER=energypi
POSTGRES_PASSWORD=

# --- Frontend / Player (runtime config) ---
# This must be reachable by browsers and by the player (ActionCable uses /cable).
# Replace lume-player.local with your actual <hostname>.local.
NUXT_PUBLIC_API_URL=http://lume-player.local:3011

# Frontend only: convenience link from dashboard to the player UI.
NUXT_PUBLIC_PLAYER_URL=http://lume-player.local:3014

# Player only (optional)
NUXT_PUBLIC_PLAYER_ID=1
NUXT_PUBLIC_HEARTBEAT_INTERVAL_MINUTES=10
NUXT_PUBLIC_DEBUG=

# --- Core optional integrations ---
EXTERNAL_UI_USERNAME=
EXTERNAL_UI_PASSWORD=
EXTERNAL_UI_COMPONENT_ID=

# DWD MOSMIX weather station ID (defaults to 10548)
DWD_MOSMIX_STATION_ID=10548

# Selenium is provided by Docker Compose as the `selenium` service.
# (No env var needed.)

# --- CORS / websockets ---
# Comma-separated list.
#
# Keep in sync with the actual URLs you use to access the apps.
CORS_ALLOWED_ORIGINS=http://lume-player.local:3012,http://lume-player.local:3014,https://lume-player.local:3012,https://lume-player.local:3014
ACTION_CABLE_ALLOWED_ORIGINS=http://lume-player.local:3014,https://lume-player.local:3014

# --- Asset upload limits (core) ---
# Optional; values are MB.
ASSET_MAX_IMAGE_MB=
ASSET_MAX_VIDEO_MB=
ASSET_MAX_PDF_MB=
ASSET_MAX_OTHER_MB=

# --- Images/tags (optional overrides) ---
# Defaults are multi-arch images suitable for arm64.
CORE_IMAGE=lumeplayer/lume:core
FRONTEND_IMAGE=lumeplayer/lume:frontend
PLAYER_IMAGE=lumeplayer/lume:player

# Optional: embed version strings visible in UIs.
CORE_GIT_VERSION=pi
FRONTEND_GIT_VERSION=pi
PLAYER_GIT_VERSION=pi

# --- Rails optional ---
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=3
WEB_CONCURRENCY=
SOLID_QUEUE_IN_PUMA=
