# Setup-time environment for `setup-lume.sh`
#
# This file is intended for variables used during installation/bootstrap.
# Docker Compose runtime variables live in `lume-pi/docker/.env`.
#
# CLI flags override any of these.

# --- Setup defaults ---
# Recommended: set this to the hostname you want the Pi to have.
# It will be reachable on the LAN as: <hostname>.local (mDNS)
LUME_HOSTNAME=lume-player

# Install avahi-daemon + libnss-mdns to make <hostname>.local resolve on the LAN.
LUME_INSTALL_MDNS=true

# If true, `setup-lume.sh` will attempt to run `docker login`.
LUME_DOCKER_LOGIN=false

# --- Docker registry login (optional) ---
# If LUME_DOCKER_LOGIN=true or you pass --docker-login.
#
# DOCKER_REGISTRY=           # empty means Docker Hub
# DOCKER_USERNAME=
# DOCKER_PASSWORD=
# DOCKER_TOKEN=

# --- Telegram (optional) ---
# Used by: `./send-image.sh` (keeps secrets out of shell history)
#
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# TELEGRAM_CHAT_ID=123456789

# --- Tailscale (optional) ---
# Used by: `./setup-tailscale.sh`
#
# If set, the script will perform non-interactive enrollment via auth key.
# Otherwise it runs interactively and prints a login URL.
#
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx
#
# Extra args appended to `tailscale up`.
# Examples:
#   TS_ARGS="--accept-dns=false"
#   TS_ARGS="--advertise-tags=tag:pi"
#
# TS_ARGS=

# --- Ethernet static IP (optional; NetworkManager / Pi OS Bookworm) ---
# Used by: `./setup-eth-static.sh`
#
# The helper creates a *separate* NM connection profile so you can switch back
# to DHCP later.
#
# ETH_STATIC_IP=10.2.60.50/24
# ETH_STATIC_GW=10.2.60.1
# ETH_STATIC_DNS="10.2.60.1 1.1.1.1"   # optional
# ETH_STATIC_CONN_NAME=lume-eth-static
# ETH_STATIC_DEVICE=eth0

# --- Backups (Borg) ---
# Backups for the Pi docker stack are configured via:
# - Script: lume-pi/setup-backup.sh
# - Secrets file (root only): /etc/backup-secrets
#
# The backup includes:
# - Postgres logical dump (pg_dump) from the `db` compose service
# - Rails ActiveStorage files from the `core_storage` docker volume
#
# Nothing to configure here by default; edit /etc/backup-secrets after install.


