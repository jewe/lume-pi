# Borg settings for Lume backups
#
# Required:
#   borg init --encryption=repokey ssh://<user>@<host>.repo.borgbase.com/./repo
#
BORG_REPO=""
BORG_PASSPHRASE=""

# Optional
BORG_COMPRESSION="lz4"
BORG_ARCHIVE_PREFIX="lume-db-storage"

# Retention
BORG_KEEP_DAILY=7
BORG_KEEP_WEEKLY=4
BORG_KEEP_MONTHLY=6

# systemd timer schedule (OnCalendar syntax)
LUME_BACKUP_ONCALENDAR="*-*-* 03:00:00"
