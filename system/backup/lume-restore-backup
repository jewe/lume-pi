#!/usr/bin/env bash
set -euo pipefail

# Guided restore helper for Lume Borg backups.
#
# This script can:
# - list archives
# - extract an archive to a local directory
# - restore the Postgres DB from the extracted db_backup.sql.gz into the db service
#
# Config:
# - /etc/backup-secrets
# - __DEFAULT_LUME_PI_DIR__/docker/.env (override with LUME_PI_DIR)

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

load_env_file() {
  local env_file="$1"
  if [[ -f "$env_file" ]]; then
    # shellcheck disable=SC1090
    set -a
    source "$env_file"
    set +a
  fi
}

usage() {
  cat <<'USAGE'
Usage:
  lume-restore-backup list
  lume-restore-backup extract <archive> [--to <dir>]
  lume-restore-backup restore-db <archive>

Examples:
  lume-restore-backup list
  lume-restore-backup extract lume-db-storage-2026-01-01T03-00-00
  lume-restore-backup restore-db lume-db-storage-2026-01-01T03-00-00

Notes:
  - The archive contains:
      - db_backup.sql.gz
      - storage.tar (tar of the Rails storage docker volume)
  - DB restore is destructive for the target database.
USAGE
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

cmd="$1"
shift

if ! has_cmd borg; then
  echo "ERROR: borg is not installed." >&2
  exit 1
fi
if ! has_cmd docker; then
  echo "ERROR: docker is not installed." >&2
  exit 1
fi
if ! docker compose version >/dev/null 2>&1; then
  echo "ERROR: docker compose plugin is not available (expected 'docker compose')." >&2
  exit 1
fi

SECRETS_FILE="/etc/backup-secrets"
if [[ ! -f "$SECRETS_FILE" ]]; then
  echo "ERROR: Secrets file not found: ${SECRETS_FILE}" >&2
  exit 1
fi
load_env_file "$SECRETS_FILE"
if [[ -z "${BORG_REPO:-}" || -z "${BORG_PASSPHRASE:-}" ]]; then
  echo "ERROR: BORG_REPO / BORG_PASSPHRASE must be set in ${SECRETS_FILE}" >&2
  exit 1
fi

export BORG_REPO
export BORG_PASSPHRASE

LUME_PI_DIR="${LUME_PI_DIR:-__DEFAULT_LUME_PI_DIR__}"
COMPOSE_DIR="${LUME_PI_DIR}/docker"
COMPOSE_ENV_FILE="${COMPOSE_DIR}/.env"
COMPOSE_FILE="${COMPOSE_DIR}/docker-compose.yml"
if [[ ! -f "$COMPOSE_ENV_FILE" || ! -f "$COMPOSE_FILE" ]]; then
  echo "ERROR: Could not find compose env/file under ${COMPOSE_DIR}" >&2
  exit 1
fi

docker_compose() {
  ( cd "$COMPOSE_DIR" && docker compose --env-file "$COMPOSE_ENV_FILE" -f "$COMPOSE_FILE" "$@" )
}

load_env_file "$COMPOSE_ENV_FILE"
POSTGRES_DB_VALUE="${POSTGRES_DB:-energypi}"
POSTGRES_USER_VALUE="${POSTGRES_USER:-energypi}"

case "$cmd" in
  list)
    borg list "${BORG_REPO}"
    ;;
  extract)
    archive="${1:-}"
    if [[ -z "$archive" ]]; then
      echo "ERROR: missing archive name" >&2
      usage
      exit 1
    fi
    shift
    to_dir=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --to)
          to_dir="${2:-}"
          shift 2
          ;;
        *)
          echo "Unknown argument: $1" >&2
          exit 1
          ;;
      esac
    done
    if [[ -z "$to_dir" ]]; then
      to_dir="/tmp/lume-restore-${archive}"
    fi
    mkdir -p "$to_dir"
    echo "==> Extracting ${archive} to ${to_dir}"
    borg extract "${BORG_REPO}::${archive}" --destination "$to_dir"
    echo "==> Extracted. You should now have:"
    echo "- ${to_dir}/db_backup.sql.gz"
    echo "- ${to_dir}/storage.tar"
    echo ""
    echo "To inspect storage tar:"
    echo "  tar -tf ${to_dir}/storage.tar | head"
    echo ""
    echo "To restore storage into a docker volume (example):"
    echo "  # WARNING: overwrites volume content"
    echo "  docker run --rm -v <storage_volume>:/storage -v ${to_dir}:/backup alpine:3.20 sh -lc 'rm -rf /storage/* && tar -C /storage -xf /backup/storage.tar'"
    ;;
  restore-db)
    archive="${1:-}"
    if [[ -z "$archive" ]]; then
      echo "ERROR: missing archive name" >&2
      usage
      exit 1
    fi
    work_dir="/tmp/lume-restore-${archive}"
    rm -rf "$work_dir"
    mkdir -p "$work_dir"
    echo "==> Extracting db from ${archive} to ${work_dir}"
    borg extract "${BORG_REPO}::${archive}" --destination "$work_dir" "db_backup.sql.gz"

    if [[ ! -f "${work_dir}/db_backup.sql.gz" ]]; then
      echo "ERROR: db_backup.sql.gz not found after extraction" >&2
      exit 1
    fi

    echo "==> Restoring DB '${POSTGRES_DB_VALUE}' (this will overwrite data!)"
    gunzip -c "${work_dir}/db_backup.sql.gz" | docker_compose exec -T db psql -U "$POSTGRES_USER_VALUE" "$POSTGRES_DB_VALUE"
    echo "==> DB restore complete"
    ;;
  *)
    echo "Unknown command: ${cmd}" >&2
    usage
    exit 1
    ;;
esac
